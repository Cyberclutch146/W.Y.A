rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ─────────────────────────────────────────────
    // Profile reads: any authenticated user (leaderboards, chat headers).
    // Profile writes: DENIED — handled exclusively by /api/user/profile (Admin SDK).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;

      // Notifications subcollection — managed by /api/notifications/create
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if false;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // User's event registrations — managed by /api/events/join (Admin SDK)
      match /registrations/{eventId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ─── Events ────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;  // Public read for landing page & feed

      // Event create/update/delete: now handled by secure API routes
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      // Chat messages — DENIED client-side, handled by /api/chat/send (Admin SDK)
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }

      // Volunteers — join is via /api/events/join, scan via /api/events/scan (Admin SDK)
      match /volunteers/{volunteerId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }

      // Goods pledges — now managed by /api/events/pledge
      match /pledges/{pledgeId} {
        allow read: if request.auth != null;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
      
      // Since it's actually goodsPledges in the client, let's deny it too to be safe
      match /goodsPledges/{pledgeId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      // Donations — now managed by /api/events/donate
      match /donations/{donationId} {
        allow read: if request.auth != null;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─── Bulletins (Campus Noticeboard) ────────────────────
    // Read: any authenticated user can browse all notices.
    // Write: DENIED client-side — all mutations go through
    //        /api/bulletin/create and /api/bulletin/delete (Admin SDK).
    match /bulletins/{bulletinId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // ─── Promotions & Logs ─────────────────────────────────
    // Exclusively written by /api/promote (Admin SDK). No client access needed.
    match /promotions/{promotionId} {
      allow read, write: if false;
    }
    match /promotion_logs/{logId} {
      allow read, write: if false;
    }

    // ─── Default deny ──────────────────────────────────────
    // Any collection not explicitly matched above is denied.
  }
}