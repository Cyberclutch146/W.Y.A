rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ─────────────────────────────────────────────
    // Profile reads: any authenticated user (leaderboards, chat headers).
    // Profile writes: DENIED — handled exclusively by /api/user/profile (Admin SDK).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;

      // Notifications subcollection — still managed client-side
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // User's event registrations — managed by /api/events/join (Admin SDK)
      match /registrations/{eventId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ─── Events ────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;  // Public read for landing page & feed

      // Event create/update/delete: still client-side for organizers
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      // Chat messages — DENIED client-side, handled by /api/chat/send (Admin SDK)
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }

      // Volunteers — join is via /api/events/join, scan via /api/events/scan (Admin SDK)
      match /volunteers/{volunteerId} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }

      // Goods pledges — still managed client-side
      match /pledges/{pledgeId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if false;
      }

      // Donations — still managed client-side (runTransaction)
      match /donations/{donationId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if false;
      }
    }

    // ─── Promotions & Logs ─────────────────────────────────
    // Exclusively written by /api/promote (Admin SDK). No client access needed.
    match /promotions/{promotionId} {
      allow read, write: if false;
    }
    match /promotion_logs/{logId} {
      allow read, write: if false;
    }

    // ─── Default deny ──────────────────────────────────────
    // Any collection not explicitly matched above is denied.
  }
}